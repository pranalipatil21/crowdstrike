# --- Python Specific ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual Environment ---
# We never upload the venv because it contains thousands of local files
venv/
.venv/
env/

# --- Large Data Files ---
# The CSV is too large for GitHub (often >50MB) 
# and should be downloaded by the user instead
*.csv

# --- Machine Learning Artifacts ---
# We ignore the model because it is generated by train_model.py
# Tracking binaries (.pkl) makes the Git history very heavy
*.pkl
*.joblib

# --- IDE Settings ---
.vscode/
.idea/

# --- OS Specific ---
.DS_Store
Thumbs.db

# --- Local Logs ---
*.log